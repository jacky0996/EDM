# --- 正式環境 Proxy 設定 (供 Vite 模擬使用) ---
VITE_PROXY_API_TARGET=http://127.0.0.1:81
VITE_PROXY_SSO_TARGET=http://127.0.0.1

# 基礎路徑
VITE_BASE=/

# 介面虛擬位址 (Nginx 接管)
VITE_GLOB_API_URL=/api/
VITE_SSO_VERIFY_URL=/api-sso/

# 路由模式
VITE_ROUTER_HISTORY=history

# 是否注入全域 Loading
VITE_INJECT_APP_LOADING=true

# SSO 串接網域 — 指向本地 Middle Platform 的 SSO 登入頁 (port 80)
VITE_HWS_URL=http://localhost/sso/
VITE_EDM_URL=http://localhost:82
