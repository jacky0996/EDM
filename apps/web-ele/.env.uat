# 介面位址 (UAT - 一般業務走中繼站，隱藏真實 IP)
VITE_GLOB_API_URL=/api/

# SSO 直接驗證位址 (隱藏域名，由 Nginx 後端處理)
VITE_SSO_VERIFY_URL=/api-sso/

# 路由模式 (改為 history 以移除 # 號)
VITE_ROUTER_HISTORY=history

# 是否注入全域 Loading
VITE_INJECT_APP_LOADING=true

# SSO 串接網址 (UAT)
VITE_HWS_URL=https://uathws.hwacom.com/
VITE_EDM_URL=https://uatedm.hwacom.com
